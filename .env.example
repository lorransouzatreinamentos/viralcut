VIRALCUT_PORT=8756
VIRALCUT_LLM=openai
VIRALCUT_LLM_MODEL=gpt-4o
# auto = tenta faster-whisper local (gratis) primeiro, cai pra API se nao
# estiver instalado (pip install faster-whisper). "api" forca sempre a nuvem.
VIRALCUT_TRANSCRIBE=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# DaVinci Resolve Studio (scripting externo) — preencher conforme o SO.
# macOS:
# RESOLVE_SCRIPT_API="/Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting"
# RESOLVE_SCRIPT_LIB="/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so"
# PYTHONPATH="$PYTHONPATH:$RESOLVE_SCRIPT_API/Modules/"
RESOLVE_SCRIPT_API=
RESOLVE_SCRIPT_LIB=
